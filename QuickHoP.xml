<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <!-- ============================================================ -->
    <!-- PALADIN MAIN FRAME                                           -->
    <!-- ============================================================ -->
    <Frame name="QuickHoPFrame" parent="UIParent" frameStrata="MEDIUM" toplevel="true" movable="true" enableMouse="true" hidden="false">
        <Size>
            <AbsDimension x="120" y="40"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Frames>
            <Button name="QuickHoPFrameButton" enableMouse="true">
                <Size>
                    <AbsDimension x="120" y="40"/>
                </Size>
                <Anchors>
                    <Anchor point="CENTER"/>
                </Anchors>
                <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background"
                          edgeFile="Interface\Tooltips\UI-Tooltip-Border"
                          tile="true">
                    <EdgeSize><AbsValue val="12"/></EdgeSize>
                    <TileSize><AbsValue val="12"/></TileSize>
                    <BackgroundInsets>
                        <AbsInset left="3" right="3" top="3" bottom="3"/>
                    </BackgroundInsets>
                </Backdrop>

                <Layers>
                    <Layer level="ARTWORK">
                        <Texture name="$parentIcon"
                                 file="Interface\Icons\Spell_Holy_SealOfProtection">
                            <Size><AbsDimension x="28" y="28"/></Size>
                            <Anchors>
                                <Anchor point="LEFT">
                                    <Offset><AbsDimension x="4" y="0"/></Offset>
                                </Anchor>
                            </Anchors>
                        </Texture>
                    </Layer>
                    <Layer level="OVERLAY">
                        <FontString name="$parentTargetText"
                                    inherits="GameFontNormal"
                                    text="No Target">
                            <Anchors>
                                <Anchor point="TOPLEFT" relativeTo="$parentIcon" relativePoint="TOPRIGHT">
                                    <Offset><AbsDimension x="4" y="0"/></Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                        <FontString name="$parentCooldownText"
                                    inherits="GameFontHighlight"
                                    text="Ready">
                            <Anchors>
                                <Anchor point="BOTTOMLEFT" relativeTo="$parentIcon" relativePoint="BOTTOMRIGHT">
                                    <Offset><AbsDimension x="4" y="0"/></Offset>
                                </Anchor>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>

                <Scripts>
                    <OnLoad>
                        this:RegisterForClicks("LeftButtonUp", "RightButtonUp")
                        this:RegisterForDrag("LeftButton")
                        this:SetBackdropColor(0.3, 0.0, 0.0, 0.8)
                    </OnLoad>
                    <OnClick>QuickHoP_Button_OnClick(this)</OnClick>
                    <OnDragStart>QuickHoPFrame:StartMoving()</OnDragStart>
                    <OnDragStop>QuickHoPFrame:StopMovingOrSizing()</OnDragStop>
                    <OnEnter>QuickHoP_Button_OnEnter()</OnEnter>
                    <OnLeave>QuickHoP_Button_OnLeave()</OnLeave>
                </Scripts>
            </Button>
        </Frames>

        <Scripts>
            <OnLoad>
                QuickHoP_OnLoad()
                this:RegisterForDrag("LeftButton")
            </OnLoad>
            <OnEvent>QuickHoP_OnEvent(event)</OnEvent>
            <OnUpdate>QuickHoP_OnUpdate(arg1)</OnUpdate>
            <OnDragStart>this:StartMoving()</OnDragStart>
            <OnDragStop>this:StopMovingOrSizing()</OnDragStop>
            <OnShow>QuickHoP_UpdateUI()</OnShow>
        </Scripts>
    </Frame>

    <!-- ============================================================ -->
    <!-- OPTIONS FRAME                                                 -->
    <!-- ============================================================ -->
    <Frame name="QuickHoPOptionsFrame" parent="UIParent" frameStrata="DIALOG"
           toplevel="true" movable="true" enableMouse="true" hidden="true">
        <Size><AbsDimension x="280" y="400"/></Size>
        <Anchors><Anchor point="CENTER"/></Anchors>
        <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background"
                  edgeFile="Interface\Tooltips\UI-Tooltip-Border"
                  tile="true">
            <EdgeSize><AbsValue val="16"/></EdgeSize>
            <TileSize><AbsValue val="16"/></TileSize>
            <BackgroundInsets>
                <AbsInset left="5" right="5" top="5" bottom="5"/>
            </BackgroundInsets>
        </Backdrop>
        <Frames>
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset><AbsDimension x="-2" y="-2"/></Offset>
                    </Anchor>
                </Anchors>
            </Button>
        </Frames>
        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton")
                this:SetBackdropColor(0.0, 0.0, 0.0, 0.9)
            </OnLoad>
            <OnDragStart>this:StartMoving()</OnDragStart>
            <OnDragStop>this:StopMovingOrSizing()</OnDragStop>
        </Scripts>
    </Frame>

    <!-- Screen flash is built entirely in Lua (QuickHoP_BuildFlash).  -->
    <!-- No XML frame needed.                                          -->

    <!-- ============================================================ -->
    <!-- CENTER ALERT ICON (Paladin notification)                     -->
    <!-- Draggable.  Glow border created in Lua via SetBackdrop.      -->
    <!-- ============================================================ -->
    <Frame name="QuickHoPAlertIcon" parent="UIParent" frameStrata="FULLSCREEN"
           toplevel="true" movable="true" enableMouse="true" hidden="true">
        <Size><AbsDimension x="64" y="64"/></Size>
        <Anchors>
            <Anchor point="CENTER" relativeTo="UIParent" relativePoint="CENTER"/>
        </Anchors>

        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentTexture"
                         file="Interface\Icons\Spell_Holy_SealOfProtection">
                    <Size><AbsDimension x="64" y="64"/></Size>
                    <Anchors><Anchor point="CENTER"/></Anchors>
                </Texture>
            </Layer>
        </Layers>

        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton")
            </OnLoad>
            <OnDragStart>this:StartMoving()</OnDragStart>
            <OnDragStop>QuickHoP_AlertIcon_OnDragStop()</OnDragStop>
        </Scripts>
    </Frame>

    <!-- ============================================================ -->
    <!-- CASTER REQUEST BUTTON (non-Paladin, assigned targets only)   -->
    <!-- Compact: icon + cooldown text, no label.                     -->
    <!-- ============================================================ -->
    <Button name="QuickHoPRequestFrame" parent="UIParent" frameStrata="MEDIUM"
            toplevel="true" movable="true" enableMouse="true" hidden="true"
            registeredForDrag="LeftButton">
        <Size><AbsDimension x="48" y="56"/></Size>
        <Anchors>
            <Anchor point="BOTTOM">
                <Offset><AbsDimension x="0" y="120"/></Offset>
            </Anchor>
        </Anchors>
        <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background"
                  edgeFile="Interface\Tooltips\UI-Tooltip-Border"
                  tile="true">
            <EdgeSize><AbsValue val="10"/></EdgeSize>
            <TileSize><AbsValue val="10"/></TileSize>
            <BackgroundInsets>
                <AbsInset left="3" right="3" top="3" bottom="3"/>
            </BackgroundInsets>
        </Backdrop>

        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentIcon"
                         file="Interface\Icons\Spell_Holy_SealOfProtection">
                    <Size><AbsDimension x="36" y="36"/></Size>
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset><AbsDimension x="0" y="-6"/></Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString name="$parentCooldownText"
                            inherits="GameFontNormalSmall"
                            text="Ready">
                    <Anchors>
                        <Anchor point="BOTTOM">
                            <Offset><AbsDimension x="0" y="5"/></Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>

        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton")
                this:SetBackdropColor(0.0, 0.0, 0.15, 0.85)
            </OnLoad>
            <OnClick>QuickHoP_RequestButton_OnClick()</OnClick>
            <OnDragStart>this:StartMoving()</OnDragStart>
            <OnDragStop>this:StopMovingOrSizing()</OnDragStop>
            <OnEnter>QuickHoP_RequestButton_OnEnter()</OnEnter>
            <OnLeave>QuickHoP_RequestButton_OnLeave()</OnLeave>
            <OnUpdate>QuickHoP_RequestFrame_OnUpdate(arg1)</OnUpdate>
        </Scripts>
    </Button>

</Ui>
